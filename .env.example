# Copy to `.env` and edit. Every value has a working default — this file only
# exists so you can override them. Docker Compose reads `.env` automatically.

# ── Postgres (compose) ───────────────────────────────────────────────────────
POSTGRES_USER=moat
POSTGRES_PASSWORD=moat
POSTGRES_DB=moat
POSTGRES_PORT=5432

# ── Redis / Open-Meteo (compose) ─────────────────────────────────────────────
REDIS_PORT=6379
OPEN_METEO_PORT=8080

# ── App / poller ─────────────────────────────────────────────────────────────
# When running the poller OUTSIDE compose, point this at your Postgres:
DATABASE_URL=postgresql://moat:moat@localhost:5432/moat
# Optional: explicit Queue-Times park IDs (comma-separated).
# Leave empty to resolve the default Orlando set by name against /parks.json.
QUEUE_TIMES_PARK_IDS=
POLL_INTERVAL_SECONDS=300
HTTP_TIMEOUT_SECONDS=15
MAX_RETRIES=4
